generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WaAuthCreds {
  sessionId String   @id
  creds     Json
  updatedAt DateTime @updatedAt
}

model WaAuthKey {
  id        BigInt   @id @default(autoincrement())
  sessionId String
  category  String
  keyId     String
  value     Json?
  updatedAt DateTime @updatedAt

  @@unique([sessionId, category, keyId])
  @@index([sessionId, category, keyId])
}
