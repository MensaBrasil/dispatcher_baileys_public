{
  "name": "dispatcher",
  "version": "1.0.0",
  "author": "Hiago Teixeira <hiagodevsolutions@gmail.com>",
  "description": "Baileys version of whatsapp dispatcher written in typescript.",
  "main": "index.js",
  "scripts": {
    "start": "pnpm build && node --max-old-space-size=4096 dist/index.js",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -b",
    "format": "pnpm biome format --write && pnpm biome lint --write && pnpm biome check --write && git add ."
  },
  "keywords": [],
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "baileys": "7.0.0-rc.9",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^5.12.1",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode-terminal": "^0.12.2",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
