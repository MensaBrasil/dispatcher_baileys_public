{
  "name": "dispatcher",
  "version": "1.0.0",
  "author": "Hiago Teixeira <hiagodevsolutions@gmail.com>",
  "description": "Baileys version of whatsapp dispatcher written in typescript.",
  "main": "index.js",
  "scripts": {
    "start": "pnpm build && node --max-old-space-size=4096 dist/index.js",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -b",
    "check": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "run-prod": "node --max-old-space-size=4096 dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "fmt": "prettier . --check",
    "fmt:write": "prettier . --write",
    "get-queues": "node dist/tools/getRedisQueue.js",
    "tools:dump-groups": "pnpm build && node dist/tools/dumpGroups.js",
    "tools:add-worker": "pnpm build && node dist/tools/addNewWorker.js",
    "tools:queue-contact-removal": "pnpm build && node dist/tools/queueContactRemoval.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "license": "ISC",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "baileys": "7.0.0-rc.9",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^5.11.0",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
